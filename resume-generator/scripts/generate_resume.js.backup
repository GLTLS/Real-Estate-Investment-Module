/**
 * 创建批处理文件
 */
function createBatchFile(outputDir, files) {
  const batchContent = `@echo off
echo Opening generated resume files...
echo.

${files.map((file, index) => {
  const fileName = path.basename(file);
  return `echo ${index + 1}. Opening ${fileName}...
start "" "${file}"
timeout /t 2 /nobreak >nul`;
}).join('\n\n')}

echo.
echo All resume files have been opened in: ${outputDir}
echo.
pause`;

  const batchPath = path.join(outputDir, 'open_resumes.bat');
  fs.writeFileSync(batchPath, batchContent);
}

module.exports = {
  generateResume,
  analyzeJobRequirements
};